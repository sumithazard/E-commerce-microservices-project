pipeline {
    agent any 

    stages {
        stage('Cleaning Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout from Git') {
            steps {
                git branch: 'main', url: 'https://github.com/sumithazard/E-commerce-microservices-project.git'
            }
        }

        stage("Docker Image Build") {
            steps {
                script {
                    dir('src/productcatalogservice') {
                        sh 'docker system prune -f'
                        sh 'docker container prune -f'
                        sh 'docker build -t productcatalogservice .'
                    }
                }
            }
        }

        stage("ECR Image Pushing") {
            steps {
                script {
                    sh '''
                    # Authenticate Docker to AWS ECR
                    aws ecr get-login-password --region us-east-1 | docker login --username AWS --password-stdin 117272619399.dkr.ecr.us-east-1.amazonaws.com

                    # Tag and push image with build number
                    docker tag productcatalogservice:latest 117272619399.dkr.ecr.us-east-1.amazonaws.com/productcatalogservice:${BUILD_NUMBER}
                    docker push 117272619399.dkr.ecr.us-east-1.amazonaws.com/productcatalogservice:${BUILD_NUMBER}
                    '''
                }
            }
        }

        stage('Update Deployment file') {
            environment {
                GIT_REPO_NAME = "E-commerce-microservices-project"
                GIT_EMAIL = "sumithazard09@gmail.com"
                GIT_USER_NAME = "sumithazard"
                IMAGE_NAME = "productcatalogservice"
                REPO_URL = "117272619399.dkr.ecr.us-east-1.amazonaws.com/productcatalogservice"
                YAML_FILE = "productcatalogservice.yaml"
            }
            steps {
                dir('kubernetes-files') {
                    withCredentials([string(credentialsId: 'my-git-pattoken', variable: 'git_token')]) {
                        sh '''
                            git config user.email "${GIT_EMAIL}"
                            git config user.name "${GIT_USER_NAME}"

                            # Ensure latest changes are pulled before commit
                            git pull https://${git_token}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME} main --rebase

                            # Update image reference in YAML
                            sed -i "s#image:.*#image: ${REPO_URL}:${BUILD_NUMBER}#g" ${YAML_FILE}

                            git add .
                            git commit -m "Update ${IMAGE_NAME} Image to version ${BUILD_NUMBER}"

                            # Push to main branch
                            git push https://${git_token}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME} HEAD:main
                        '''
                    }
                }
            }
        }
    }
}

